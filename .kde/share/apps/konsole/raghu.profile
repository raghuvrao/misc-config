[Appearance]
AntiAliasFonts=true
BoldIntense=false
ColorScheme=raghu-dark
Font=Liberation Mono,10,-1,5,75,0,0,0,0,0

[General]
Command=/bin/bash
Environment=TERM=xterm-256color
LocalTabTitleFormat=%w
Name=raghu
Parent=FALLBACK/
RemoteTabTitleFormat=%H
SaveGeometryOnExit=false
ShowMenuBar=false
ShowNewAndCloseTabButtons=false
TabBarMode=2
TabBarPosition=1

[Interaction Options]
AutoCopySelectedText=true
UnderlineLinksEnabled=false
WordCharacters=:-./_~?&=%+#

[Scrolling]
HistorySize=2048

[Terminal Features]
BlinkingCursorEnabled=true
